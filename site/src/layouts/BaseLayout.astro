---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = "Claude Code History",
  description = "A modern narrative and release explorer for Claude Code's full evolution.",
  currentPath = "/",
} = Astro.props;

const navItems = [
  { href: "/", label: "首页" },
  { href: "/explore", label: "Explore" },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="page-shell font-sans antialiased">
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div class="hero-orb left-[-8rem] top-[8rem] h-64 w-64 bg-[radial-gradient(circle,_rgba(134,167,197,0.28),_rgba(134,167,197,0))]"></div>
      <div class="hero-orb right-[-10rem] top-[20rem] h-80 w-80 bg-[radial-gradient(circle,_rgba(203,178,140,0.26),_rgba(203,178,140,0))] [animation-delay:1.2s]"></div>
      <div class="hero-orb bottom-[-10rem] left-1/3 h-96 w-96 bg-[radial-gradient(circle,_rgba(142,167,147,0.18),_rgba(142,167,147,0))] [animation-delay:2s]"></div>
    </div>

    <header class="sticky top-0 z-50 border-b border-[var(--page-line)] bg-[rgba(245,241,235,0.74)] backdrop-blur-xl">
      <div class="section-shell flex h-[4.5rem] items-center justify-between gap-6">
        <a href="/" class="flex items-center gap-3 text-sm font-medium tracking-[0.16em] text-[var(--page-ink)] uppercase">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-[var(--page-line)] bg-white/70 text-[0.72rem]">CC</span>
          <span>Claude Code History</span>
        </a>

        <nav class="flex items-center gap-2 text-sm text-[var(--page-muted)]">
          {navItems.map((item) => {
            const active = currentPath === item.href;
            return (
              <a
                href={item.href}
                class:list={[
                  "rounded-full px-4 py-2 transition",
                  active
                    ? "bg-white/80 text-[var(--page-ink)] shadow-[0_10px_30px_-22px_rgba(31,38,46,0.6)]"
                    : "hover:bg-white/50 hover:text-[var(--page-ink)]",
                ]}
              >
                {item.label}
              </a>
            );
          })}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="section-shell border-t border-[var(--page-line)] py-8 text-sm text-[var(--page-muted)]">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <p>Claude Code History</p>
        <p class="font-mono text-xs tracking-[0.2em] uppercase">Astro 5 · React 19 · Tailwind 4</p>
      </div>
    </footer>

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("revealed");
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.08, rootMargin: "0px 0px -40px 0px" }
      );
      document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
    </script>
  </body>
</html>

---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  descriptionEn?: string;
  currentPath?: string;
}

const {
  title = "Claude Code Chronicle",
  description = "A narrative journal of the evolution from command-line helper to agentic platform.",
  descriptionEn,
  currentPath = "/",
} = Astro.props;

const navItems = [
  { href: "/", label: "Home" },
  { href: "/explore", label: "Explore" },
];
---

<!doctype html>
<html class="scroll-smooth" lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} data-desc-en={descriptionEn || description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#fdf9f3" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,700;1,6..72,400&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <!-- Detect language before paint: localStorage > browser locale > default EN -->
    <script is:inline>
      (function() {
        var stored = localStorage.getItem("lang");
        var lang;
        if (stored === "cn" || stored === "en") {
          lang = stored;
        } else {
          var nav = (navigator.languages && navigator.languages[0]) || navigator.language || "";
          lang = /^zh\b/i.test(nav) ? "cn" : "en";
        }
        if (lang === "cn") {
          document.documentElement.removeAttribute("data-lang");
          document.documentElement.lang = "zh-CN";
        } else {
          document.documentElement.setAttribute("data-lang", "en");
          document.documentElement.lang = "en";
          var md = document.querySelector('meta[name="description"]');
          if (md && md.dataset.descEn) md.setAttribute("content", md.dataset.descEn);
        }
      })();
    </script>
  </head>
  <body class="bg-surface text-primary selection:bg-secondary-container selection:text-on-secondary-container">
    <!-- TopNavBar -->
    <nav class="fixed top-0 w-full z-50 glass-nav shadow-[0_20px_40px_rgba(31,38,46,0.04)]">
      <div class="flex justify-between items-center w-full px-8 py-4 max-w-7xl mx-auto">
        <a href="/" class="text-xl font-bold tracking-tighter text-primary font-headline">
          Claude Code Chronicle
        </a>

        <div class="hidden md:flex gap-8 items-center">
          {navItems.map((item) => {
            const active = currentPath === item.href;
            return (
              <a
                href={item.href}
                class:list={[
                  "font-label text-xs uppercase tracking-[0.2em] transition-colors duration-300",
                  active
                    ? "text-primary font-bold border-b-2 border-primary pb-1"
                    : "text-primary/60 hover:text-primary",
                ]}
              >
                {item.label}
              </a>
            );
          })}

          <div class="flex items-center gap-2 ml-4 border-l border-outline-variant/30 pl-8">
            <button
              id="lang-cn"
              type="button"
              class="text-primary font-bold font-label text-[10px] uppercase tracking-[0.2em] cursor-pointer hover:opacity-80 transition-opacity"
            >CN</button>
            <span class="text-primary/20 font-label text-[10px]">/</span>
            <button
              id="lang-en"
              type="button"
              class="text-primary/40 font-label text-[10px] uppercase tracking-[0.2em] cursor-pointer hover:opacity-80 transition-opacity"
            >EN</button>
          </div>
        </div>

        <div class="flex items-center gap-4 md:hidden">
          <button id="lang-toggle-mobile" type="button" class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-primary cursor-pointer">
            <span class="i18n-cn">EN</span>
            <span class="i18n-en">CN</span>
          </button>
          <span class="material-symbols-outlined text-primary cursor-pointer">menu</span>
        </div>
      </div>
    </nav>

    <main class="pt-32 pb-20 px-8 max-w-7xl mx-auto space-y-32">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-surface-container-low text-primary mt-20 py-12 px-8">
      <div class="flex flex-col md:flex-row justify-between items-center max-w-7xl mx-auto w-full gap-8">
        <div class="space-y-2">
          <div class="text-md font-bold text-primary font-headline">Claude Code Chronicle</div>
          <p class="label-md opacity-50">Astro 5 · React 19 · Tailwind 4</p>
        </div>
        <div class="flex gap-8 label-md uppercase tracking-widest font-bold">
          <a class="text-secondary hover:text-primary transition-colors" href="https://docs.anthropic.com/en/docs/claude-code" target="_blank" rel="noreferrer">Official Docs</a>
          <a class="text-secondary hover:text-primary transition-colors" href="https://www.anthropic.com/blog" target="_blank" rel="noreferrer">Blog</a>
          <a class="text-secondary hover:text-primary transition-colors" href="/explore">Explore Archive</a>
        </div>
      </div>
    </footer>

    <script>
      // --- Scroll reveal ---
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("revealed");
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.08, rootMargin: "0px 0px -40px 0px" }
      );
      document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));

      // --- Language toggle ---
      function setLang(lang: "cn" | "en") {
        const html = document.documentElement;
        if (lang === "en") {
          html.setAttribute("data-lang", "en");
          html.lang = "en";
          localStorage.setItem("lang", "en");
        } else {
          html.removeAttribute("data-lang");
          html.lang = "zh-CN";
          localStorage.setItem("lang", "cn");
        }
        updateLangButtons(lang);
        // Swap meta description
        const md = document.querySelector('meta[name="description"]') as HTMLMetaElement | null;
        if (md) {
          const descEn = md.dataset.descEn || "";
          const descCn = md.dataset.descCn || md.getAttribute("content") || "";
          if (!md.dataset.descCn) md.dataset.descCn = descCn;
          md.setAttribute("content", lang === "en" ? descEn : md.dataset.descCn);
        }
      }

      function updateLangButtons(lang: "cn" | "en") {
        const cnBtn = document.getElementById("lang-cn");
        const enBtn = document.getElementById("lang-en");
        if (cnBtn && enBtn) {
          cnBtn.className = cnBtn.className.replace(/text-primary(\/\d+)?/g, "").trim();
          enBtn.className = enBtn.className.replace(/text-primary(\/\d+)?/g, "").trim();
          if (lang === "cn") {
            cnBtn.classList.add("text-primary", "font-bold");
            enBtn.classList.add("text-primary/40");
            enBtn.classList.remove("font-bold");
          } else {
            enBtn.classList.add("text-primary", "font-bold");
            cnBtn.classList.add("text-primary/40");
            cnBtn.classList.remove("font-bold");
          }
        }
      }

      document.getElementById("lang-cn")?.addEventListener("click", () => setLang("cn"));
      document.getElementById("lang-en")?.addEventListener("click", () => setLang("en"));
      document.getElementById("lang-toggle-mobile")?.addEventListener("click", () => {
        const current = document.documentElement.getAttribute("data-lang");
        setLang(current === "en" ? "cn" : "en");
      });

      // Initialize button state on load
      updateLangButtons(document.documentElement.getAttribute("data-lang") === "en" ? "en" : "cn");
    </script>
  </body>
</html>

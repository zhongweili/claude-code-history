---
interface EpochBrief {
  id: string;
  name: string;
  name_en: string;
  color: string;
  releases: string[];
}

interface Props {
  hero: {
    headline: string;
    subheadline: string;
    highlights: { label: string; value: string | number }[];
  };
  meta: {
    total_versions: number;
    date_range: { start: string; end: string };
    hn_signals_count: number;
    blog_posts_count: number;
    story: {
      milestone_count: number;
      capability_count: number;
    };
  };
  epochs: EpochBrief[];
}

const { hero, meta, epochs } = Astro.props;

const statCards = [
  { cn: "关键章节", en: "CHAPTERS", value: String(meta.story.milestone_count) },
  { cn: "能力主线", en: "CAPABILITIES", value: String(meta.story.capability_count).padStart(2, "0") },
  { cn: "版本总数", en: "RELEASES", value: String(meta.total_versions) },
  { cn: "HN 热帖", en: "HN THREADS", value: String(meta.hn_signals_count) },
];

const maxReleases = Math.max(...epochs.map((e) => e.releases.length));
---

<section class="reveal grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
  <div class="lg:col-span-7 space-y-6">
    <span class="kicker text-secondary">
      <span class="i18n-cn">编年纪事</span>
      <span class="i18n-en">A Chronicle</span>
    </span>
    <h1 class="text-primary font-headline font-black leading-[1.15]" style="font-size: clamp(2.2rem, 5vw, 3.5rem);">
      <span class="i18n-cn" style="letter-spacing: 0.01em;">一年，<br />254 次更新</span>
      <span class="i18n-en" style="letter-spacing: -0.04em;">One Year,<br />254 Updates</span>
    </h1>
    <p class="title-lg text-on-surface-variant max-w-xl" style="line-height: 1.8;">
      <span class="i18n-cn">从研究预览到 1M 上下文的代理，从 ultrathink 到 Opus 4.6——这是 Claude Code 完整的一年。</span>
      <span class="i18n-en">From research preview to a 1M-context agent, from ultrathink to Opus 4.6 — this is Claude Code's full year, laid out end to end.</span>
    </p>
  </div>

  <div class="lg:col-span-5 grid grid-cols-2 gap-4 reveal" data-delay="1">
    {statCards.map((stat) => (
      <div class="bg-surface-container-low p-6 rounded-xl flex flex-col justify-between h-32">
        <span class="label-md opacity-60">
          <span class="i18n-cn">{stat.cn}</span>
          <span class="i18n-en">{stat.en}</span>
        </span>
        <span class="headline-md">{stat.value}</span>
      </div>
    ))}
  </div>

  <div class="lg:col-span-12 mt-12 reveal" data-delay="2">
    <div class="bg-surface-container-low p-8 rounded-xl relative overflow-hidden">
      <div class="flex justify-between items-end h-40 gap-2">
        {epochs.map((epoch) => {
          const count = epoch.releases.length;
          const bars = [
            { opacity: 0.2, height: Math.max(20, (count / maxReleases) * 60) },
            { opacity: 0.5, height: Math.max(30, (count / maxReleases) * 100) },
          ];
          return bars.map((bar) => (
            <div
              class="flex-1 rounded-sm transition-all hover:opacity-80"
              style={`height: ${bar.height}%; background: ${epoch.color}; opacity: ${bar.opacity};`}
            />
          ));
        })}
      </div>
      <div class="flex justify-between mt-4 label-md opacity-40">
        {epochs.map((epoch) => (
          <span>
            <span class="i18n-cn">{epoch.name}</span>
            <span class="i18n-en">{epoch.name_en}</span>
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

---
interface Highlight {
  label: string;
  value: string | number;
}

interface EpochBrief {
  id: string;
  name: string;
  name_en: string;
  releases: string[];
}

interface Props {
  hero: {
    headline: string;
    subheadline: string;
    highlights: Highlight[];
  };
  meta: {
    total_versions: number;
    date_range: {
      start: string;
      end: string;
    };
  };
  epochs: EpochBrief[];
}

const { hero, meta, epochs } = Astro.props;

const maxReleases = Math.max(...epochs.map((e) => e.releases.length));
const toneColors = [
  "var(--tone-blue)",
  "var(--tone-steel)",
  "var(--tone-sage)",
  "var(--tone-champagne)",
  "var(--tone-coral)",
];

const leadStats = [
  {
    label: "版本跨度",
    value: `${meta.total_versions}+`,
    caption: `${meta.date_range.start} → ${meta.date_range.end}`,
  },
  ...hero.highlights.map((item) => ({
    label: item.label,
    value: String(item.value),
    caption: "Editorial story layer",
  })),
].slice(0, 4);
---

<section class="section-shell relative pt-16 sm:pt-24 lg:pt-28">
  <div class="surface-panel grid gap-12 overflow-hidden px-6 py-8 sm:px-10 sm:py-10 lg:grid-cols-[minmax(0,1.15fr)_minmax(18rem,0.85fr)] lg:px-14 lg:py-16">
    <div class="reveal relative z-10">
      <p class="section-kicker">Claude Code Evolution</p>
      <h1 class="mt-6 max-w-4xl text-balance text-5xl font-semibold tracking-[-0.06em] text-[var(--page-ink)] sm:text-6xl lg:text-7xl">
        {hero.headline}
      </h1>
      <p class="mt-6 max-w-2xl text-balance text-base leading-8 text-[var(--page-muted)] sm:text-lg">
        {hero.subheadline}
      </p>

      <div class="mt-10 flex flex-col gap-3 sm:flex-row">
        <a
          href="#milestones"
          class="inline-flex items-center justify-center rounded-full bg-[var(--page-ink)] px-6 py-3 text-sm font-medium text-white transition hover:translate-y-[-1px]"
        >
          进入时间叙事
        </a>
        <a
          href="/explore"
          class="inline-flex items-center justify-center rounded-full border border-[var(--page-line)] bg-white/75 px-6 py-3 text-sm font-medium text-[var(--page-ink)] transition hover:bg-white"
        >
          打开完整版本入口
        </a>
      </div>
    </div>

    <div class="reveal relative min-h-[22rem] lg:min-h-[28rem]" data-delay="1">
      <div class="absolute inset-0 rounded-[2rem] bg-[linear-gradient(145deg,rgba(255,255,255,0.96),rgba(255,255,255,0.45))]"></div>
      <div class="absolute inset-x-5 top-5 h-px bg-[linear-gradient(90deg,transparent,rgba(42,48,56,0.18),transparent)]"></div>

      <div class="relative flex flex-col gap-4 px-7 pt-8 lg:px-9 lg:pt-10">
        <p class="text-[0.68rem] uppercase tracking-[0.3em] text-[var(--page-muted)]">
          Release Density by Epoch
        </p>
        {epochs.map((epoch, i) => {
          const count = epoch.releases.length;
          const barWidth = Math.max(18, (count / maxReleases) * 100);
          return (
            <div>
              <div class="flex items-baseline justify-between gap-3">
                <span class="text-xs font-medium text-[var(--page-ink)]">{epoch.name}</span>
                <span class="font-mono text-xs tabular-nums text-[var(--page-muted)]">{count}</span>
              </div>
              <div class="mt-1.5 h-2 overflow-hidden rounded-full bg-black/[0.04]">
                <div
                  class="h-full rounded-full"
                  style={`width:${barWidth}%; background: ${toneColors[i] || toneColors[0]};`}
                />
              </div>
            </div>
          );
        })}
      </div>

      <div class="absolute inset-x-5 bottom-5 grid gap-3 sm:grid-cols-2">
        {leadStats.map((item, index) => (
          <div class="surface-card p-4">
            <p class="text-[0.72rem] uppercase tracking-[0.24em] text-[var(--page-muted)]">
              0{index + 1} · {item.label}
            </p>
            <p class="mt-3 text-3xl font-semibold tracking-[-0.05em] text-[var(--page-ink)]">
              {item.value}
            </p>
            <p class="mt-2 text-sm text-[var(--page-muted)]">{item.caption}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

---
interface OfficialPost {
  slug: string;
  title: string;
  date: string;
  summary: string;
  url: string;
}

interface FeaturedHn {
  objectID: string;
  title: string;
  date: string;
  url: string;
  external_url?: string;
  points: number;
  comments: number;
  domain: string;
  theme: string;
  tone: string;
}

interface Props {
  socialProof: {
    official_posts: OfficialPost[];
    featured_hn: FeaturedHn[];
    themes: {
      id: string;
      count: number;
      share: number;
    }[];
    tones: {
      id: string;
      count: number;
      share: number;
    }[];
  };
}

const { socialProof } = Astro.props as Props;
---

<section class="reveal grid grid-cols-1 lg:grid-cols-2 gap-16 border-t border-outline-variant/10 pt-20">
  <!-- Official Blog -->
  <div class="space-y-8">
    <div class="space-y-2">
      <span class="kicker text-secondary">
        <span class="i18n-cn">官方声音</span>
        <span class="i18n-en">Official Voice</span>
      </span>
      <h3 class="headline-md">Anthropic Blog</h3>
    </div>
    <div class="space-y-6">
      {socialProof.official_posts.map((post) => (
        <a
          href={post.url}
          target="_blank"
          rel="noreferrer"
          class="group cursor-pointer block"
        >
          <span class="label-md text-primary/40">
            {new Date(post.date).toLocaleDateString("en-US", {
              month: "short",
              day: "numeric",
              year: "numeric",
            }).toUpperCase()}
          </span>
          <h4 class="title-lg group-hover:text-secondary transition-colors">
            {post.title}
          </h4>
          {post.summary && (
            <p class="body-lg text-sm text-on-surface-variant mt-2">{post.summary}</p>
          )}
          <div class="h-[1px] w-0 group-hover:w-full bg-secondary transition-all duration-500 mt-4" />
        </a>
      ))}
    </div>
  </div>

  <!-- Hacker News -->
  <div class="space-y-8">
    <div class="space-y-2">
      <span class="kicker text-error">
        <span class="i18n-cn">社区信号</span>
        <span class="i18n-en">Community Signal</span>
      </span>
      <h3 class="headline-md">Hacker News</h3>
    </div>
    <div class="space-y-4">
      {socialProof.featured_hn.slice(0, 5).map((item) => (
        <a
          href={item.url}
          target="_blank"
          rel="noreferrer"
          class="bg-surface-container-low p-4 rounded-lg flex items-center justify-between group hover:shadow-md transition-all block"
        >
          <div class="space-y-1">
            <p class="font-bold text-sm font-headline">{item.title}</p>
            <span class="label-md opacity-40">
              {item.points.toLocaleString()} points · {item.comments} comments
            </span>
          </div>
          <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity">
            arrow_outward
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

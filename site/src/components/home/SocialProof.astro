---
interface OfficialPost {
  slug: string;
  title: string;
  date: string;
  summary: string;
  url: string;
}

interface FeaturedHn {
  objectID: string;
  title: string;
  date: string;
  url: string;
  external_url?: string;
  points: number;
  comments: number;
  domain: string;
  theme: string;
  tone: string;
}

interface Props {
  socialProof: {
    official_posts: OfficialPost[];
    featured_hn: FeaturedHn[];
    themes: {
      id: string;
      count: number;
      share: number;
    }[];
    tones: {
      id: string;
      count: number;
      share: number;
    }[];
  };
}

const { socialProof } = Astro.props as Props;
---

<section class="section-shell pt-20 sm:pt-24">
  <div class="reveal max-w-3xl">
    <p class="section-kicker">Social Proof</p>
    <h2 class="section-title mt-4">官方叙事与社区反应，共同决定了产品被怎样理解</h2>
    <p class="section-copy mt-5">
      这部分把官方发布和 HN 热点放在同一画面里。你能看到它何时被热议、为什么被热议，以及这种热度围绕的主题。
    </p>
  </div>

  <div class="reveal mt-10 grid gap-6 xl:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]" data-delay="1">
    <div class="surface-panel px-6 py-6">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-[var(--page-muted)]">Official Posts</p>
          <h3 class="mt-3 text-2xl font-semibold tracking-[-0.04em] text-[var(--page-ink)]">
            官方叙事线
          </h3>
        </div>
        <span class="rounded-full border border-[var(--page-line)] bg-white/75 px-3 py-1 text-xs text-[var(--page-muted)]">
          {socialProof.official_posts.length} posts
        </span>
      </div>

      <div class="mt-6 space-y-3">
        {socialProof.official_posts.map((post) => (
          <a
            href={post.url}
            target="_blank"
            rel="noreferrer"
            class="block rounded-[1.4rem] border border-[var(--page-line)] bg-white/62 p-5 transition hover:bg-white/92"
          >
            <p class="text-xs uppercase tracking-[0.18em] text-[var(--page-muted)]">{post.date}</p>
            <h4 class="mt-3 text-lg font-medium tracking-[-0.03em] text-[var(--page-ink)]">
              {post.title}
            </h4>
            <p class="mt-3 text-sm leading-7 text-[var(--page-muted)]">{post.summary}</p>
          </a>
        ))}
      </div>
    </div>

    <div class="space-y-6">
      <div class="surface-panel px-6 py-6">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-xs uppercase tracking-[0.22em] text-[var(--page-muted)]">Community Heat</p>
            <h3 class="mt-3 text-2xl font-semibold tracking-[-0.04em] text-[var(--page-ink)]">
              Hacker News 热度切片
            </h3>
          </div>
          <span class="rounded-full border border-[var(--page-line)] bg-white/75 px-3 py-1 text-xs text-[var(--page-muted)]">
            {socialProof.featured_hn.length} signals
          </span>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          {socialProof.featured_hn.slice(0, 6).map((item, index) => (
            <a
              href={item.url}
              target="_blank"
              rel="noreferrer"
              class:list={[
                "rounded-[1.4rem] border border-[var(--page-line)] bg-[linear-gradient(135deg,rgba(255,255,255,0.84),rgba(255,255,255,0.56))] p-4 transition hover:bg-white/92",
                index === 0 ? "sm:col-span-2" : "",
              ]}
            >
              <div class="flex items-center justify-between gap-3">
                <span class="text-xs uppercase tracking-[0.18em] text-[var(--page-muted)]">{item.date}</span>
                <span class="rounded-full border border-[var(--page-line)] px-2.5 py-1 text-xs text-[var(--page-muted)]">
                  {item.points} pts
                </span>
              </div>
              <h4 class="mt-3 text-lg font-medium tracking-[-0.03em] text-[var(--page-ink)]">
                {item.title}
              </h4>
              <div class="mt-4 flex flex-wrap gap-2 text-xs text-[var(--page-muted)]">
                <span class="rounded-full bg-white/80 px-3 py-1">{item.domain}</span>
                <span class="rounded-full bg-white/80 px-3 py-1">{item.comments} comments</span>
                <span class="rounded-full bg-white/80 px-3 py-1">{item.theme}</span>
              </div>
            </a>
          ))}
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <div class="surface-card p-5">
          <p class="text-xs uppercase tracking-[0.22em] text-[var(--page-muted)]">Top Themes</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {socialProof.themes.slice(0, 6).map((item) => (
              <span class="rounded-full border border-[var(--page-line)] bg-white/70 px-3 py-1 text-xs text-[var(--page-ink)]">
                {item.id} · {item.count}
              </span>
            ))}
          </div>
        </div>
        <div class="surface-card p-5">
          <p class="text-xs uppercase tracking-[0.22em] text-[var(--page-muted)]">Tone Mix</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {socialProof.tones.slice(0, 6).map((item) => (
              <span class="rounded-full border border-[var(--page-line)] bg-white/70 px-3 py-1 text-xs text-[var(--page-ink)]">
                {item.id} · {item.count}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

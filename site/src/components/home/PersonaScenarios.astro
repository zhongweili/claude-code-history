---
interface Persona {
  id: string;
  name: string;
  name_en?: string;
  summary: string;
  jobs_to_be_done: string[];
  maturity: {
    score: number;
    level: string;
  };
  capabilities: {
    id: string;
    name: string;
  }[];
  milestones: {
    id: string;
    title: string;
    date: string;
  }[];
}

const { personas } = Astro.props as { personas: Persona[] };
---

<section class="section-shell pt-20 sm:pt-24">
  <div class="reveal max-w-3xl">
    <p class="section-kicker">Persona Scenarios</p>
    <h2 class="section-title mt-4">把"能做什么"翻译成"谁因此受益"</h2>
    <p class="section-copy mt-5">
      首页不是写给只关心 release notes 的人。这里用角色和任务来解释 Claude Code 如何从工程工具，扩展成更广泛的知识工作界面。
    </p>
  </div>

  <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {personas.map((persona, index) => (
      <article
        class="reveal surface-card p-5"
        data-delay={String(Math.min(index + 1, 3))}
      >
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-xs uppercase tracking-[0.22em] text-[var(--page-muted)]">{persona.name_en}</p>
            <h3 class="mt-3 text-2xl font-semibold tracking-[-0.04em] text-[var(--page-ink)]">
              {persona.name}
            </h3>
          </div>
          <span class="rounded-full bg-[var(--page-ink)] px-3 py-1 text-xs font-medium text-white">
            {persona.maturity.score}
          </span>
        </div>

        <p class="mt-4 text-sm leading-7 text-[var(--page-muted)]">{persona.summary}</p>

        <ul class="mt-5 space-y-2">
          {persona.jobs_to_be_done.map((job) => (
            <li class="flex gap-3 text-sm text-[var(--page-ink)]">
              <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--tone-champagne)]"></span>
              {job}
            </li>
          ))}
        </ul>

        <div class="mt-5 flex flex-wrap gap-2">
          {persona.capabilities.slice(0, 4).map((capability) => (
            <span class="rounded-full bg-[rgba(134,167,197,0.12)] px-3 py-1 text-xs font-medium text-[var(--page-ink)]">
              {capability.name}
            </span>
          ))}
        </div>
      </article>
    ))}
  </div>
</section>

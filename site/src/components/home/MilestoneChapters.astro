---
interface Epoch {
  id: string;
  name: string;
  name_en: string;
  period_start: string;
  period_end: string;
  color: string;
  summary: string;
  summary_en?: string;
  key_events: string[];
  milestone_count: number;
}

interface Milestone {
  id: string;
  date: string;
  title: string;
  title_en?: string;
  summary: string;
  summary_en?: string;
  why_it_matters: string;
  why_it_matters_en?: string;
  epoch_id: string;
  capabilities: { id: string; name: string; name_en?: string }[];
  personas: { id: string; name: string }[];
  evidence: {
    type: string;
    title: string;
    title_en?: string;
    url?: string;
    points?: number;
  }[];
  evidence_summary: {
    official_sources: number;
    community_sources: number;
    release_sources: number;
  };
  asset_ids: string[];
}

interface Asset {
  id: string;
  brief: string;
  status: string;
}

interface Props {
  epochs: Epoch[];
  milestones: Milestone[];
  assets: {
    items: Asset[];
    coverage: {
      missing_count: number;
      total_count: number;
    };
  };
}

const { epochs, milestones } = Astro.props;

const chapters = epochs
  .map((epoch) => ({
    ...epoch,
    milestones: milestones.filter((milestone) => milestone.epoch_id === epoch.id),
  }))
  .filter((chapter) => chapter.milestones.length > 0);

const epochIcons: Record<string, string> = {
  epoch1: "history_edu",
  epoch2: "build",
  epoch3: "hub",
  epoch4: "layers",
  epoch5: "smart_toy",
};

const epochCssClass: Record<string, string> = {
  epoch1: "epoch-genesis",
  epoch2: "epoch-toolification",
  epoch3: "epoch-ecosystem",
  epoch4: "epoch-platformization",
  epoch5: "epoch-autonomization",
};
---

<section id="milestones" class="reveal grid grid-cols-1 lg:grid-cols-12 gap-16">
  <!-- Sticky Epoch Sidebar -->
  <aside class="lg:col-span-3">
    <div class="sticky top-28 space-y-8">
      <div class="space-y-2">
        <span class="kicker text-primary">
          <span class="i18n-cn">演进阶段</span>
          <span class="i18n-en">EPOCHS</span>
        </span>
        <h2 class="headline-md">
          <span class="i18n-cn">进化阶段</span>
          <span class="i18n-en">Evolution Phases</span>
        </h2>
      </div>
      <nav class="flex flex-col gap-2">
        {epochs.map((epoch) => (
          <a
            href={`#epoch-${epoch.id}`}
            class="flex items-center gap-3 text-primary/50 hover:bg-surface-container-low transition-all p-3 rounded-md"
            data-epoch-nav={epoch.id}
          >
            <span
              class="material-symbols-outlined"
              style={`color: ${epoch.color};`}
            >
              {epochIcons[epoch.id] || "circle"}
            </span>
            <span class="label-md">{epoch.name_en.toUpperCase()}</span>
          </a>
        ))}
      </nav>
    </div>
  </aside>

  <!-- Content Area -->
  <div class="lg:col-span-9 space-y-24">
    {chapters.map((chapter) => (
      <div
        id={`epoch-${chapter.id}`}
        data-epoch-section={chapter.id}
        class="space-y-12 scroll-mt-28"
      >
        <!-- Epoch Header -->
        <div class={`border-l-4 pl-6 ${epochCssClass[chapter.id] || ""}`}>
          <span class="kicker">
            <span class="i18n-cn">{chapter.name_en} / {chapter.name}</span>
            <span class="i18n-en">{chapter.name_en}</span>
          </span>
          <p class="title-lg mt-2 text-on-surface-variant">
            <span class="i18n-cn">{chapter.summary}</span>
            <span class="i18n-en">{chapter.summary_en || chapter.summary}</span>
          </p>
        </div>

        <!-- Milestone Cards -->
        <div class="grid grid-cols-1 gap-8">
          {chapter.milestones.map((milestone) => (
            <div class="reveal bg-surface-container-low p-8 rounded-xl space-y-6">
              <div class="flex justify-between items-start">
                <h3 class="headline-md">
                  <span class="i18n-cn">{milestone.title}</span>
                  <span class="i18n-en">{milestone.title_en || milestone.title}</span>
                </h3>
                <span class="label-md text-primary/40 shrink-0 ml-4">{milestone.date}</span>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-4">
                  <p class="body-lg italic text-on-surface-variant">
                    <span class="i18n-cn">"{milestone.why_it_matters}"</span>
                    <span class="i18n-en">"{milestone.why_it_matters_en || milestone.why_it_matters}"</span>
                  </p>
                  <div class="flex flex-wrap gap-2">
                    {milestone.capabilities.slice(0, 4).map((cap) => (
                      <span class="bg-white/50 px-2 py-1 label-md rounded">
                        <span class="i18n-cn">{cap.name}</span>
                        <span class="i18n-en">{cap.name_en || cap.name}</span>
                      </span>
                    ))}
                  </div>
                </div>

                <div class="space-y-3 text-sm">
                  {milestone.evidence.slice(0, 3).map((item) => (
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noreferrer"
                      class="flex items-center gap-2 text-primary/70 hover:text-primary transition-colors"
                    >
                      <span class="material-symbols-outlined text-sm">
                        {item.type === "community" ? "trending_up" : "link"}
                      </span>
                      <span class="truncate">
                        <span class="i18n-cn">{item.title}</span>
                        <span class="i18n-en">{item.title_en || item.title}</span>
                        {item.points ? ` · ${item.points} pts` : ""}
                      </span>
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const sections = document.querySelectorAll<HTMLElement>("[data-epoch-section]");
  const navLinks = document.querySelectorAll<HTMLElement>("[data-epoch-nav]");

  const observer = new IntersectionObserver(
    (entries) => {
      const visible = entries
        .filter((e) => e.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
      if (visible[0]?.target instanceof HTMLElement) {
        const activeId = visible[0].target.dataset.epochSection;
        navLinks.forEach((link) => {
          const isActive = link.dataset.epochNav === activeId;
          link.classList.toggle("bg-surface-container-lowest", isActive);
          link.classList.toggle("shadow-sm", isActive);
          link.classList.toggle("text-primary", isActive);
          link.classList.toggle("font-bold", isActive);
          link.classList.toggle("text-primary/50", !isActive);
        });
      }
    },
    { rootMargin: "-30% 0px -50% 0px", threshold: [0.2, 0.4, 0.6] }
  );

  sections.forEach((s) => observer.observe(s));
</script>

---
interface Capability {
  id: string;
  name: string;
  name_en?: string;
  summary: string;
  summary_en?: string;
  description: string;
  maturity: {
    score: number;
    level: string;
  };
  first_seen?: {
    date: string;
    version: string;
  };
  latest_seen?: {
    date: string;
    version: string;
  };
  audiences: string[];
  samples: {
    date: string;
    summary: string;
    raw: string;
  }[];
}

const { capabilities } = Astro.props as { capabilities: Capability[] };

const maturityLevelEn: Record<string, string> = {
  "成熟": "Mature",
  "成型": "Established",
  "增长中": "Growing",
  "早期": "Early",
};

const capIcons = [
  "psychology",
  "terminal",
  "memory",
  "auto_mode",
  "architecture",
  "security",
  "integration_instructions",
  "tune",
];

const barColors = [
  "var(--color-secondary)",
  "var(--color-toolification)",
  "var(--color-ecosystem)",
  "var(--color-platformization)",
  "var(--color-genesis)",
  "var(--color-autonomization)",
  "var(--color-secondary)",
  "var(--color-toolification)",
];
---

<section class="reveal space-y-12">
  <div class="text-center space-y-4">
    <span class="kicker text-secondary">
      <span class="i18n-cn">能力图谱</span>
      <span class="i18n-en">Capability Atlas</span>
    </span>
    <h2 class="display-lg">
      <span class="i18n-cn">核心能力图谱</span>
      <span class="i18n-en">Core Capability Atlas</span>
    </h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    {capabilities.map((cap, index) => (
      <div
        class="reveal bg-surface-container-low p-6 rounded-xl space-y-6 hover:bg-surface-container-high transition-colors"
        data-delay={String(Math.min(index + 1, 4))}
      >
        <div class="flex justify-between items-center">
          <span class="material-symbols-outlined text-secondary">
            {capIcons[index] || "circle"}
          </span>
          <span class="label-md opacity-40">
            {String(index + 1).padStart(2, "0")}
          </span>
        </div>

        <div>
          <h4 class="font-bold font-headline">
            <span class="i18n-cn">{cap.name}</span>
            <span class="i18n-en">{cap.name_en || cap.name}</span>
          </h4>
          <span class="label-md opacity-50 uppercase">
            <span class="i18n-cn">{cap.name_en}</span>
            <span class="i18n-en">{cap.name}</span>
          </span>
        </div>

        <p class="body-lg text-sm text-on-surface-variant">
          <span class="i18n-cn">{cap.summary}</span>
          <span class="i18n-en">{cap.summary_en || cap.summary}</span>
        </p>

        <div class="space-y-2">
          <div class="flex justify-between label-md">
            <span>
              <span class="i18n-cn">成熟度</span>
              <span class="i18n-en">Maturity</span>
            </span>
            <span>{cap.maturity.score}%</span>
          </div>
          <div class="h-[2px] w-full bg-outline-variant/20">
            <div
              class="h-full"
              style={`width: ${cap.maturity.score}%; background: ${barColors[index]};`}
            />
          </div>
          <div class="flex justify-between text-[10px] opacity-40 font-bold uppercase tracking-wider font-label">
            <span>
              <span class="i18n-cn">首次: {cap.first_seen?.date || "N/A"}</span>
              <span class="i18n-en">First: {cap.first_seen?.date || "N/A"}</span>
            </span>
            <span>
              <span class="i18n-cn">{cap.maturity.level}</span>
              <span class="i18n-en">{maturityLevelEn[cap.maturity.level] || cap.maturity.level}</span>
            </span>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

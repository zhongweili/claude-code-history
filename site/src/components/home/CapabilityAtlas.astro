---
interface Capability {
  id: string;
  name: string;
  name_en?: string;
  summary: string;
  description: string;
  maturity: {
    score: number;
    level: string;
  };
  first_seen?: {
    date: string;
    version: string;
  };
  latest_seen?: {
    date: string;
    version: string;
  };
  audiences: string[];
  samples: {
    date: string;
    summary: string;
    raw: string;
  }[];
}

const { capabilities } = Astro.props as { capabilities: Capability[] };

const toneColors = [
  "var(--tone-blue)",
  "var(--tone-steel)",
  "var(--tone-sage)",
  "var(--tone-champagne)",
  "var(--tone-coral)",
  "var(--tone-blue)",
  "var(--tone-steel)",
  "var(--tone-sage)",
];
---

<section class="section-shell pt-24 sm:pt-28">
  <div class="reveal grid gap-8 lg:grid-cols-[minmax(0,18rem)_1fr]">
    <div>
      <p class="section-kicker">Capability Atlas</p>
      <h2 class="section-title mt-4">八条能力主线，组成 Claude Code 的真正成长曲线</h2>
      <p class="section-copy mt-5">
        这里不按版本号组织，而按能力域组织。你能看到每条能力线第一次出现、成熟度，以及最能代表它的变化样本。
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      {capabilities.map((capability, index) => (
        <article
          class="reveal surface-card p-5"
          data-delay={String(Math.min(index + 1, 4))}
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-xs uppercase tracking-[0.22em] text-[var(--page-muted)]">
                {capability.name_en}
              </p>
              <h3 class="mt-3 text-2xl font-semibold tracking-[-0.04em] text-[var(--page-ink)]">
                {capability.name}
              </h3>
            </div>
            <div class="rounded-full bg-[var(--page-ink)] px-3 py-1 text-xs font-medium text-white">
              {capability.maturity.level}
            </div>
          </div>

          <p class="mt-4 text-sm leading-7 text-[var(--page-muted)]">{capability.summary}</p>

          <div class="mt-5">
            <div class="flex items-center justify-between text-xs uppercase tracking-[0.18em] text-[var(--page-muted)]">
              <span>Maturity</span>
              <span>{capability.maturity.score}</span>
            </div>
            <div class="mt-2 h-2 overflow-hidden rounded-full bg-black/5">
              <div
                class="h-full rounded-full"
                style={`width:${capability.maturity.score}%; background: ${toneColors[index]};`}
              ></div>
            </div>
          </div>

          <div class="mt-5 flex items-center gap-6 text-sm text-[var(--page-muted)]">
            <div>
              <p class="text-xs uppercase tracking-[0.18em]">First seen</p>
              <p class="mt-1 font-medium text-[var(--page-ink)]">
                {capability.first_seen?.date}
              </p>
            </div>
            <div class="h-8 w-px bg-[var(--page-line)]"></div>
            <div>
              <p class="text-xs uppercase tracking-[0.18em]">Latest</p>
              <p class="mt-1 font-medium text-[var(--page-ink)]">
                {capability.latest_seen?.date}
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

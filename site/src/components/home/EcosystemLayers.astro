---
interface Track {
  id: string;
  name: string;
  name_en?: string;
  summary: string;
  capabilities: {
    id: string;
    name: string;
    maturity: {
      score: number;
    };
  }[];
  milestones: {
    id: string;
    title: string;
    date: string;
  }[];
  surface_area: {
    total_changes: number;
  };
}

const { tracks } = Astro.props as { tracks: Track[] };
---

<section class="section-shell pt-24 sm:pt-28">
  <div class="reveal grid gap-8 lg:grid-cols-[minmax(0,18rem)_1fr]">
    <div>
      <p class="section-kicker">Ecosystem Layers</p>
      <h2 class="section-title mt-4">从认知层到信任层，Claude Code 正在长成一个平台</h2>
      <p class="section-copy mt-5">
        这不是单点功能的堆叠。它逐步形成了认知、执行、协作、平台、界面和治理六层结构。
      </p>
    </div>

    <div class="space-y-4">
      {tracks.map((track, index) => (
        <article class="reveal surface-panel px-5 py-5 sm:px-6" data-delay={String(Math.min(index + 1, 3))}>
          <div class="grid gap-5 lg:grid-cols-[12rem_minmax(0,1fr)] lg:items-start">
            <div>
              <p class="text-xs uppercase tracking-[0.22em] text-[var(--page-muted)]">
                Layer 0{index + 1}
              </p>
              <h3 class="mt-3 text-2xl font-semibold tracking-[-0.04em] text-[var(--page-ink)]">
                {track.name}
              </h3>
              <p class="mt-2 text-sm uppercase tracking-[0.18em] text-[var(--page-muted)]">
                {track.name_en}
              </p>
            </div>

            <div>
              <p class="text-sm leading-7 text-[var(--page-muted)]">{track.summary}</p>

              <div class="mt-5 flex flex-wrap gap-2">
                {track.capabilities.map((capability) => (
                  <span class="rounded-full bg-[rgba(134,167,197,0.12)] px-3 py-1 text-xs font-medium text-[var(--page-ink)]">
                    {capability.name} · {capability.maturity.score}
                  </span>
                ))}
              </div>

              <div class="mt-5 grid gap-3 md:grid-cols-3">
                {track.milestones.map((milestone) => (
                  <div class="rounded-2xl border border-[var(--page-line)] bg-white/62 p-4">
                    <p class="text-xs uppercase tracking-[0.18em] text-[var(--page-muted)]">{milestone.date}</p>
                    <p class="mt-2 text-sm text-[var(--page-ink)]">{milestone.title}</p>
                  </div>
                ))}
              </div>

              <p class="mt-5 text-xs uppercase tracking-[0.18em] text-[var(--page-muted)]">
                Surface area · {track.surface_area.total_changes} tracked changes
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import ExploreApp from "../components/explore/ExploreApp";
import exploreData from "../generated/explore-data.json";
import type { ExploreData } from "../lib/data/schema";

const data = exploreData as ExploreData;
---

<BaseLayout
  title="Explore | Claude Code Chronicle"
  description="完整浏览 Claude Code 的版本、变更、社区信号和能力标签。"
  descriptionEn="Browse all Claude Code releases, changes, community signals, and capability tags."
  currentPath="/explore"
>
  <header class="mb-12">
    <h1 class="text-5xl font-black font-headline tracking-tighter mb-4">Explore History</h1>
    <p class="font-body text-xl text-secondary max-w-2xl leading-relaxed italic">
      <span class="i18n-cn">穿越 Claude Code 的进化历程，从最初的代码生成到如今的自主智能平台。</span>
      <span class="i18n-en">Journey through Claude Code's evolution, from initial code generation to today's autonomous intelligent platform.</span>
    </p>
  </header>

  <div>
    <ExploreApp client:only="react" data={data} />
  </div>
</BaseLayout>

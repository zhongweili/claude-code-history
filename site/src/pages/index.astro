---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/home/HeroSection.astro";
import MilestoneChapters from "../components/home/MilestoneChapters.astro";
import CapabilityAtlas from "../components/home/CapabilityAtlas.astro";
import SocialProof from "../components/home/SocialProof.astro";
import ExploreCta from "../components/home/ExploreCta.astro";
import storyHomeData from "../generated/story-home.json";
---

<BaseLayout
  title="Claude Code Chronicle"
  description="记录从命令行辅助工具到智能代理平台的演变历程。"
  descriptionEn="A narrative chronicle of Claude Code's evolution from CLI helper to agentic platform."
  currentPath="/"
>
  <HeroSection hero={storyHomeData.hero} meta={storyHomeData.meta} epochs={storyHomeData.epochs} />

  <MilestoneChapters
    epochs={storyHomeData.epochs}
    milestones={storyHomeData.milestones}
    assets={storyHomeData.assets}
  />

  <CapabilityAtlas capabilities={storyHomeData.capabilities} />

  <SocialProof socialProof={storyHomeData.social_proof} />

  <ExploreCta />
</BaseLayout>
